{
  "name": "tandem-server",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @tandem/server --filter @tandem/web dev",
    "dev:server": "pnpm --filter @tandem/server dev",
    "dev:web": "pnpm --filter @tandem/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
